# Supabase project credentials — from Supabase Dashboard → Settings → API.
# Both keys are injected at BUILD time by Vite (VITE_ prefix is required).
# The anon key is safe to expose publicly — RLS policies in schema.sql validate writes.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# For local testing you can override via URL params instead of editing .env:
#   http://localhost:5173/?supabaseUrl=https://...&supabaseKey=eyJ...
